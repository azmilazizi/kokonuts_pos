<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Two-column layout: welcome / order / payment screens -->
    <LinearLayout
        android:id="@+id/twoColumnLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- ── Left panel: promo image (purely visual, no text) ── -->
        <FrameLayout
            android:id="@+id/leftPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#E67E22">

            <ImageView
                android:id="@+id/ivPromo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/llPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/flutter_logo"
                    android:alpha="0.55" />
            </LinearLayout>

            <!-- DuitNow QR overlay: replaces promo image when QR payment is active -->
            <LinearLayout
                android:id="@+id/llDuitNowLeft"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:visibility="gone"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvDuitNowAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#212121"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:paddingBottom="14dp" />

                <ImageView
                    android:id="@+id/ivDuitNowQr"
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan to Pay with DuitNow"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    android:paddingTop="14dp" />

            </LinearLayout>
        </FrameLayout>

        <!-- ── Right panel: welcome / order / payment screens ── -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FFFFFF">

            <!-- Welcome screen -->
            <LinearLayout
                android:id="@+id/screenWelcome"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome!"
                    android:textColor="#E67E22"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="10dp"
                    android:text="What would you like today?"
                    android:textColor="#9E9E9E"
                    android:textSize="20sp" />
            </LinearLayout>

            <!-- Order screen -->
            <LinearLayout
                android:id="@+id/screenOrder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:id="@+id/itemsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp" />
                </ScrollView>

                <!-- Summary section (subtotal / discount / cashback) pinned above footer -->
                <LinearLayout
                    android:id="@+id/summaryContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp"
                    android:background="#F9F9F9"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/summaryRows"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>

                <!-- Total footer: time (bottom-left) + amount (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#E67E22"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:alpha="0.85" />

                    <TextView
                        android:id="@+id/tvOrderTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Payment screen -->
            <LinearLayout
                android:id="@+id/screenPayment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amount Due"
                    android:textColor="#9E9E9E"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvPaymentAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:textColor="#E67E22"
                    android:textSize="64sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>

    <!-- ── Full-screen complete overlay (shown after payment, covers both columns) ── -->
    <LinearLayout
        android:id="@+id/screenComplete"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Top: Thank you (orange) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:background="#E67E22"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THANK YOU!"
                android:textColor="#FFFFFF"
                android:textSize="72sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="10dp"
                android:text="We appreciate your purchase!"
                android:textColor="#FFE0B2"
                android:textSize="24sp" />
        </LinearLayout>

        <!-- Middle: Total paid + Collection number side by side (white) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Total paid -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Paid"
                    android:textColor="#9E9E9E"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvTotalPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="6dp"
                    android:textColor="#212121"
                    android:textSize="52sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Vertical divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="110dp"
                android:background="#E0E0E0" />

            <!-- Collection number -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Collection No."
                    android:textColor="#9E9E9E"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvQueueNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="6dp"
                    android:textColor="#E67E22"
                    android:textSize="72sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom: Cashback + QR reminder (warm amber) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:background="#FFF8E1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You have 10% cashback!"
                android:textColor="#E67E22"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Scan the QR code on your receipt to redeem"
                android:textColor="#757575"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
